generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
    APPLIED
    INTERVIEW
    OFFER
    REJECTED
    GHOSTED
}

model Application {

  id          String @id @default(uuid())
  companyName String 
  roleTitle   String
  location    String?
  status      ApplicationStatus @default(APPLIED)
  appliedDate DateTime?
  notes       String?
  createdAt   DateTime 
  updatedAt   DateTime 
}